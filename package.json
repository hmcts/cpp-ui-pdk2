{
  "name": "cpp.ui.pdk",
  "version": "19.0.5",
  "repository": {
    "type": "git",
    "url": "https://github.com/hmcts/cpp-ui-pdk2"
  },
  "license": "UNLICENSED",
  "scripts": {
    "ng": "ng",
    "start": "ng serve --project=docs --port 4201",
    "build": "ng build pdk && ng build application",
    "build-docs": "ng build docs --prod --aot",
    "test": "ng test",
    "lint": "ng lint",
    "preci:test": "npm run build",
    "format": "pretty-quick --staged",
    "ci:pdk": "ng build pdk",
    "ci:application": "ng build application",
    "ci:docs": "npm run build-docs",
    "ci:lint": "mkdirp ./build/lint && ng lint --format checkstyle | sed 's/Linting.*$//' > ./build/lint/checkstyle-result.xml",
    "ci:test": "ng test --coverage --ci --no-cache",
    "ci:build": "npm run build",
    "ci:aot": "exit 0",
    "ci:lint:sonar": "exit 0",
    "ci:nsp": "mkdirp ./build/dependency-check && nsp check --reporter owasp 1> ./build/dependency-check/dependency-check-report.xml || rm ./build/dependency-check/dependency-check-report.xml || true",
    "ci:prepublish": "node scripts/version.ts",
    "ci:publish": "npm run ci:prepublish && npm publish dist/@cpp/pdk && npm publish dist/@cpp/application",
    "jest:clearCache": "jest --clearCache"
  },
  "husky": {
    "hooks": {
      "pre-commit": "run-s format lint"
    }
  },
  "dependencies": {
    "@angular/animations": "^19.2.14",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.14",
    "@angular/compiler": "^19.2.14",
    "@angular/core": "^19.2.14",
    "@angular/forms": "^19.2.14",
    "@angular/platform-browser": "^19.2.14",
    "@angular/platform-browser-dynamic": "^19.2.14",
    "@angular/router": "^19.2.14",
    "@kolkov/angular-editor": "^2.1.0",
    "@ng-select/ng-select": "^14.9.0",
    "@ngrx/operators": "^19.2.1",
    "@types/jasminewd2": "^2.0.8",
    "core-js": "^2.5.4",
    "govuk-frontend": "^5.11.2",
    "prismjs": "^1.15.0",
    "rxjs": "~7.8.2",
    "zone.js": "~0.15.1"
  },
  "devDependencies": {
    "@angular-builders/jest": "^19.0.1",
    "@angular-devkit/build-angular": "^19.2.15",
    "@angular-eslint/builder": "^19.8.1",
    "@angular-eslint/eslint-plugin": "^19.8.1",
    "@angular-eslint/eslint-plugin-template": "^19.8.1",
    "@angular-eslint/schematics": "^19.8.1",
    "@angular-eslint/template-parser": "^19.8.1",
    "@angular/cli": "^19.2.15",
    "@angular/compiler-cli": "^19.2.14",
    "@angular/language-service": "^19.2.14",
    "@cpp/core": "^19.0.0-upgrade.3",
    "@cpp/users-groups": "^19.0.0-upgrade.3",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/store": "^19.2.1",
    "@types/jest": "^29.5.14",
    "@types/node": "~8.9.4",
    "@typescript-eslint/eslint-plugin": "^8.38.0",
    "@typescript-eslint/parser": "^8.38.0",
    "axe-webdriverjs": "^1.1.1",
    "eslint": "^9.32.0",
    "husky": "^4.2.5",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-jasmine2": "^29.7.0",
    "jest-preset-angular": "^14.5.4",
    "lodash-es": "^4.17.21",
    "mkdirp": "^0.5.1",
    "ng-packagr": "^19.2.2",
    "ngx-bootstrap": "^19.0.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.4",
    "pretty-quick": "^3.1.3",
    "rxjs-marbles": "^7.0.1",
    "ts-jest": "^29.4.1",
    "ts-node": "^10.9.1",
    "tslib": "^2.0.0",
    "typescript": "~5.8.3",
    "uuid": "3.3.2"
  }
}
