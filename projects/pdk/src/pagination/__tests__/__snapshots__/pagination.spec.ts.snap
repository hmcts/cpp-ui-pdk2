            pdk-margin-horizontal="1"
          >
            <span
              aria-label="Current page, page 1"
              class="pdk-pagination__item__active"
              role="link"
              tabindex="0"
            >
              1
            </span>
          </div>
          <div
            class="govuk-pagination__item govuk-!-margin-left-1 govuk-!-margin-right-1"
            pdk-margin-horizontal="1"
          >
            <a
              aria-label="Go to page 2"
              class="govuk-pagination__link govuk-link"
              href="javascript:void(0)"
              pdk-link=""
            >
               2 
