exports[`PaginationComponent should cap the visible pages according to the \`maxPages\` flag 1`] = `
<pdk-pagination-test
  currentPage={[Function Number]}
  maxPages={[Function Number]}
  pageChange={[Function Function]}
  pageSize={[Function Number]}
