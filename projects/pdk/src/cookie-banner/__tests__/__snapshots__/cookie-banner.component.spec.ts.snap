exports[`pdk-cookie-banner should render 1`] = `
<pdk-cookie-banner-test>
  <pdk-cookie-banner
    class="govuk-template--rebranded"
    heading="Cookies on Service"
  >
    <div
      aria-label="Cookies on Service"
      class="govuk-cookie-banner"
      data-nosnippet=""
      role="region"
    >
      <div
        class="govuk-width-container"
      >
        <pdk-grid
          class="govuk-grid-row"
          container=""
        >
          <pdk-grid
            class="govuk-grid-column-two-thirds"
            two-thirds=""
          >
            <h2
              class="govuk-cookie-banner__heading govuk-heading-m"
              pdk-typography="heading-medium"
            >
               Cookies on Service 
            </h2>
          </pdk-grid>
        </pdk-grid>
        <pdk-cookie-banner-content>
          <pdk-grid
            class="govuk-grid-row"
            container=""
          >
            <pdk-grid
              class="govuk-grid-column-two-thirds"
              two-thirds=""
            >
              <div
                class="pdk-cookie-banner__content"
              >
                <p>
                  We use some essential cookies to make this service work.
                </p>
                <p>
                   We’d like to set additional cookies so we can remember your settings, understand how people use the service and make improvements. 
                </p>
              </div>
            </pdk-grid>
          </pdk-grid>
        </pdk-cookie-banner-content>
        <pdk-button-group>
          <div
            class="govuk-button-group"
          >
            <button
              class="govuk-button"
              pdk-button=""
            >
              Accept additional cookies
            </button>
            <button
              class="govuk-button"
              pdk-button=""
            >
              Reject additional cookies
            </button>
          </div>
        </pdk-button-group>
      </div>
    </div>
  </pdk-cookie-banner>
</pdk-cookie-banner-test>
`;
