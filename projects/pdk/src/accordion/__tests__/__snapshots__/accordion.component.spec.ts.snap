exports[`pdk-accordion should display summary of content section when provide 1`] = `
<pdk-accordion-test
  onOpenChange={[Function Function]}
  summary={[Function String]}
>
  <pdk-accordion>
    <div
      class="govuk-accordion"
    >
      <div
        class="govuk-accordion__controls"
      >
        <button
          aria-expanded="false"
          class="govuk-accordion__show-all"
          type="button"
        >
          <span
            class="govuk-accordion-nav__chevron govuk-accordion-nav__chevron--down"
          />
          <span
            class="govuk-accordion__show-all-text"
          >
             Open all
            <span
              class="govuk-visually-hidden"
              pdk-visually-hidden=""
            >
               sections
            </span>
          </span>
        </button>
      </div>
      <pdk-accordion-item
        title="Item #1"
      >
        <div
          class="govuk-accordion__section"
        >
          <div
            class="govuk-accordion__section-header"
          >
            <h2
              class="govuk-accordion__section-heading"
            >
              <button
                aria-controls="govuk-accordion-GENERATED_ID-content"
                aria-expanded="false"
                class="govuk-accordion__section-button"
                id="govuk-accordion-GENERATED_ID-heading"
                type="button"
              >
                <span
                  class="govuk-accordion__section-heading-text"
                >
                  <span
                    class="govuk-accordion__section-heading-text-focus"
                  >
                     Item #1 
                  </span>
                </span>
                <span
                  class="govuk-accordion__section-toggle"
                  data-nosnippet=""
                >
                  <span
                    class="govuk-accordion__section-toggle-focus"
                  >
                    <span
                      aria-hidden="true"
                      class="govuk-accordion-nav__chevron govuk-accordion-nav__chevron--down"
                    />
                    <span
                      class="govuk-accordion__section-toggle-text"
                    >
                       Show 
                    </span>
                  </span>
                </span>
              </button>
            </h2>
          </div>
          <div
            aria-labelledby="govuk-accordion-GENERATED_ID-heading"
            class="govuk-accordion__section-content"
            hidden="until-found"
            id="govuk-accordion-GENERATED_ID-content"
          >
            Accordion item #1
          </div>
        </div>
      </pdk-accordion-item>
      <pdk-accordion-item
        title="Item #2"
      >
        <div
          class="govuk-accordion__section"
        >
          <div
            class="govuk-accordion__section-header"
          >
            <h2
              class="govuk-accordion__section-heading"
            >
              <button
                aria-controls="govuk-accordion-GENERATED_ID-content"
                aria-expanded="false"
                class="govuk-accordion__section-button"
                id="govuk-accordion-GENERATED_ID-heading"
                type="button"
              >
                <span
                  class="govuk-accordion__section-heading-text"
                >
                  <span
                    class="govuk-accordion__section-heading-text-focus"
                  >
                     Item #2 
                  </span>
                </span>
                <span
                  class="govuk-accordion__section-toggle"
                  data-nosnippet=""
                >
                  <span
                    class="govuk-accordion__section-toggle-focus"
                  >
                    <span
                      aria-hidden="true"
                      class="govuk-accordion-nav__chevron govuk-accordion-nav__chevron--down"
                    />
                    <span
                      class="govuk-accordion__section-toggle-text"
                    >
                       Show 
                    </span>
                  </span>
                </span>
              </button>
            </h2>
          </div>
          <div
            aria-labelledby="govuk-accordion-GENERATED_ID-heading"
            class="govuk-accordion__section-content"
            hidden="until-found"
            id="govuk-accordion-GENERATED_ID-content"
          >
            Accordion item #2
          </div>
        </div>
      </pdk-accordion-item>
      <pdk-accordion-item
        title="Item #3"
      >
        <div
          class="govuk-accordion__section"
        >
          <div
            class="govuk-accordion__section-header"
          >
            <h2
              class="govuk-accordion__section-heading"
            >
              <button
                aria-controls="govuk-accordion-GENERATED_ID-content"
                aria-describedby="govuk-accordion-GENERATED_ID-summary"
                aria-expanded="false"
                class="govuk-accordion__section-button"
                id="govuk-accordion-GENERATED_ID-heading"
                type="button"
              >
                <span
                  class="govuk-accordion__section-heading-text"
                >
                  <span
                    class="govuk-accordion__section-heading-text-focus"
                  >
                     Item #3 
                  </span>
                </span>
                <span
                  class="govuk-accordion__section-toggle"
                  data-nosnippet=""
                >
                  <span
                    class="govuk-accordion__section-toggle-focus"
                  >
                    <span
                      aria-hidden="true"
                      class="govuk-accordion-nav__chevron govuk-accordion-nav__chevron--down"
                    />
                    <span
                      class="govuk-accordion__section-toggle-text"
                    >
                       Show 
                    </span>
                  </span>
                </span>
              </button>
            </h2>
            <div
              class="govuk-accordion__section-summary govuk-body-m"
              id="govuk-accordion-GENERATED_ID-summary"
              pdk-typography="body"
            >
               Summary for content 
            </div>
          </div>
          <div
            aria-labelledby="govuk-accordion-GENERATED_ID-heading"
            class="govuk-accordion__section-content"
            hidden="until-found"
            id="govuk-accordion-GENERATED_ID-content"
          >
            Accordion item #3
          </div>
        </div>
      </pdk-accordion-item>
    </div>
  </pdk-accordion>
</pdk-accordion-test>
`;

