exports[`cpp-application-layout cookies when the cookies preferences are not yet set should accept reject all cookies when prompted 1`] = `
<cpp-application-layout-test
  accessibilityLink=""
  activity="false"
  apiError="false"
  cookieMessage={[Function Boolean]}
  feedback={[Function Function]}
  headerNavItems={[Function Array]}
  offline="false"
  phaseType={[Function String]}
  search={[Function Function]}
  searchEnabled="false"
  searchLabel=""
  searchPlaceholder=""
  serviceName={[Function String]}
