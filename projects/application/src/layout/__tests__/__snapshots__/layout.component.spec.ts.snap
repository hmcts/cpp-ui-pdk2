                    </button>
                    <a
                      class="govuk-link"
                      href="/cookies?referrer=http%3A%2F%2Flocalhost%2F"
                      pdk-link=""
                    >
                      View cookies
                    </a>
                  </div>
                </pdk-button-group>
              </div>
