exports[`cpp-application-layout cookies when the cookies preferences are not yet set should display the cookies banner 1`] = `
<cpp-application-layout-test
  accessibilityLink=""
  activity="false"
  apiError="false"
  cookieMessage={[Function Boolean]}
  feedback={[Function Function]}
  headerNavItems={[Function Array]}
  offline="false"
  phaseType={[Function String]}
  search={[Function Function]}
  searchEnabled="false"
  searchLabel=""
  searchPlaceholder=""
  serviceName={[Function String]}
  showDownTimeBanner={[Function Boolean]}
  supportEmails={[Function Array]}
  termsLink=""
>
  <cpp-application-layout
    cookieslink="/cookies"
  >
    <pdk-provider
      style="--container-width: 1170px;"
    >
      <div
        class="js-enabled govuk-frontend-supported govuk-template--rebranded"
      >
        <pdk-skip-link
          target="main-content"
        >
          <a
            class="govuk-skip-link"
            href="javascript:void(0)"
          >
             Skip to main content 
          </a>
        </pdk-skip-link>
        <cpp-application-cookies-banner>
          <pdk-cookie-banner
            class="govuk-template--rebranded"
            heading="Cookies on Common Platform"
          >
            <div
              aria-label="Cookies on Common Platform"
              class="govuk-cookie-banner"
              data-nosnippet=""
              role="region"
            >
              <div
                class="govuk-width-container"
              >
                <pdk-grid
                  class="govuk-grid-row"
                  container=""
                >
                  <pdk-grid
                    class="govuk-grid-column-two-thirds"
                    two-thirds=""
                  >
                    <h2
                      class="govuk-cookie-banner__heading govuk-heading-m"
                      pdk-typography="heading-medium"
                    >
                       Cookies on Common Platform 
                    </h2>
                  </pdk-grid>
                </pdk-grid>
                <pdk-cookie-banner-content>
                  <pdk-grid
                    class="govuk-grid-row"
                    container=""
                  >
                    <pdk-grid
                      class="govuk-grid-column-two-thirds"
                      two-thirds=""
                    >
                      <div
                        class="pdk-cookie-banner__content"
                      >
                        <p
                          class="govuk-body-m"
                          pdk-typography="body"
                        >
                          We use some essential cookies to make the application work.
                        </p>
                        <p
                          class="govuk-body-m"
                          pdk-typography="body"
                        >
                           We’d like to set additional cookies to understand how you use Common Platform, remember your settings and improve your experience. 
                        </p>
                      </div>
                    </pdk-grid>
                  </pdk-grid>
                </pdk-cookie-banner-content>
                <pdk-button-group>
                  <div
                    class="govuk-button-group"
                  >
                    <button
                      class="govuk-button"
                      data-test-id="acceptCookies"
                      pdk-button=""
                    >
