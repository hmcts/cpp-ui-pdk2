exports[`cpp-application-layout cookies when the cookies preferences are not yet set should accept all cookies when prompted 1`] = `
<cpp-application-layout-test
  accessibilityLink=""
  activity="false"
  apiError="false"
  cookieMessage={[Function Boolean]}
  feedback={[Function Function]}
  headerNavItems={[Function Array]}
  offline="false"
  phaseType={[Function String]}
  search={[Function Function]}
  searchEnabled="false"
  searchLabel=""
  searchPlaceholder=""
  serviceName={[Function String]}
  showDownTimeBanner={[Function Boolean]}
  supportEmails={[Function Array]}
  termsLink=""
>
  <cpp-application-layout
    cookieslink="/cookies"
  >
    <pdk-provider
      style="--container-width: 1170px;"
    >
      <div
        class="js-enabled govuk-frontend-supported govuk-template--rebranded"
      >
        <pdk-skip-link
          target="main-content"
        >
          <a
            class="govuk-skip-link"
            href="javascript:void(0)"
          >
             Skip to main content 
          </a>
        </pdk-skip-link>
        <cpp-application-cookies-banner>
          <pdk-cookie-banner
            class="govuk-template--rebranded"
            heading="Cookies on Common Platform"
          >
            <div
              aria-label="Cookies on Common Platform"
              class="govuk-cookie-banner"
              data-nosnippet=""
              role="region"
            >
              <div
                class="govuk-width-container"
              >
                <pdk-grid
                  class="govuk-grid-row"
                  container=""
                >
                  <pdk-grid
                    class="govuk-grid-column-two-thirds"
                    two-thirds=""
                  >
                    <h2
                      class="govuk-cookie-banner__heading govuk-heading-m"
                      pdk-typography="heading-medium"
                    >
                       Cookies on Common Platform 
                    </h2>
                  </pdk-grid>
                </pdk-grid>
                <pdk-cookie-banner-content>
                  <pdk-grid
                    class="govuk-grid-row"
                    container=""
                  >
                    <pdk-grid
                      class="govuk-grid-column-two-thirds"
                      two-thirds=""
                    >
                      <div
                        class="pdk-cookie-banner__content"
                      >
                        <p
                          class="govuk-body-m"
                          pdk-typography="body"
                        >
                          We use some essential cookies to make the application work.
                        </p>
                        <p
                          class="govuk-body-m"
                          pdk-typography="body"
                        >
                           We’d like to set additional cookies to understand how you use Common Platform, remember your settings and improve your experience. 
                        </p>
                      </div>
                    </pdk-grid>
                  </pdk-grid>
                </pdk-cookie-banner-content>
                <pdk-button-group>
                  <div
                    class="govuk-button-group"
                  >
                    <button
                      class="govuk-button"
                      data-test-id="acceptCookies"
                      pdk-button=""
                    >
                       Accept additional cookies 
                    </button>
                    <button
                      class="govuk-button"
                      data-test-id="rejectCookies"
                      pdk-button=""
                    >
                       Reject additional cookies 
                    </button>
                    <a
                      class="govuk-link"
                      href="/cookies?referrer=http%3A%2F%2Flocalhost%2F"
                      pdk-link=""
                    >
                      View cookies
                    </a>
                  </div>
                </pdk-button-group>
              </div>
            </div>
          </pdk-cookie-banner>
          <pdk-cookie-banner
            class="govuk-template--rebranded"
          >
            <div
              class="govuk-cookie-banner"
              data-nosnippet=""
              role="region"
            >
              <div
                class="govuk-width-container"
              >
                <pdk-cookie-banner-content>
                  <pdk-grid
                    class="govuk-grid-row"
                    container=""
                  >
                    <pdk-grid
                      class="govuk-grid-column-two-thirds"
                      two-thirds=""
                    >
                      <div
                        class="pdk-cookie-banner__content"
                      >
                        <p
                          class="govuk-body-m"
                          pdk-typography="body"
                        >
                           You have accepted additional cookies. You can 
                          <a
                            class="govuk-link"
                            href="/cookies?referrer=http%3A%2F%2Flocalhost%2F"
                            pdk-link=""
                          >
                            change your cookie settings
                          </a>
                           at any time. 
                        </p>
                      </div>
                    </pdk-grid>
                  </pdk-grid>
                </pdk-cookie-banner-content>
                <pdk-button-group>
                  <div
                    class="govuk-button-group"
                  >
                    <button
                      aria-label="Hide cookies message"
                      class="govuk-button"
                      data-test-id="hideCookiesBanner"
                      pdk-button=""
                    >
                       Hide this message 
                    </button>
                  </div>
                </pdk-button-group>
              </div>
            </div>
          </pdk-cookie-banner>
