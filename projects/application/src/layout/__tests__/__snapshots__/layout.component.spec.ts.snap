exports[`cpp-application-layout should render an offline warning 1`] = `
<cpp-application-layout-test
  accessibilityLink=""
  activity="false"
  apiError="false"
  cookieMessage={[Function Boolean]}
  feedback={[Function Function]}
  headerNavItems={[Function Array]}
  offline={[Function Boolean]}
  phaseType={[Function String]}
  search={[Function Function]}
  searchEnabled="false"
