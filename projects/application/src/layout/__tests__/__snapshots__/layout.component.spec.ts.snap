exports[`cpp-application-layout should render an activity indicator 1`] = `
<cpp-application-layout-test
  accessibilityLink=""
  activity={[Function Boolean]}
  apiError="false"
  cookieMessage={[Function Boolean]}
  feedback={[Function Function]}
  headerNavItems={[Function Array]}
  offline="false"
  phaseType={[Function String]}
  search={[Function Function]}
  searchEnabled="false"
  searchLabel=""
  searchPlaceholder=""
  serviceName={[Function String]}
  showDownTimeBanner={[Function Boolean]}
  supportEmails={[Function Array]}
  termsLink=""
>
  <cpp-application-layout
    cookieslink="/cookies"
  >
    <pdk-provider
      style="--container-width: 1170px;"
    >
      <div
        class="js-enabled govuk-frontend-supported govuk-template--rebranded"
      >
        <pdk-activity-indicator>
          <div
            class="pdk-activity-indicator"
          >
            <div
              class="pdk-activity-indicator__loader"
              role="status"
            >
              <div
                class="pdk-activity-indicator__spinner"
              />
              <b
                class="pdk_activity-indicator__title"
              >
                Page loading
              </b>
              <p
                style="margin-top: 4px;"
              >
                This may take a moment, please wait.
              </p>
            </div>
          </div>
          <div
            class="pdk-activity-indicator__backdrop"
          />
        </pdk-activity-indicator>
        <pdk-skip-link
          target="main-content"
        >
          <a
            class="govuk-skip-link"
            href="javascript:void(0)"
